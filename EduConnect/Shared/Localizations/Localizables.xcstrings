    "registration_checkEmailSubtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Please enter the 6-digit code sent to your email address. If you didn’t receive the message, check your «Spam» folder or request a resend."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пожалуйста, введите 6-значный код, отправленный на ваш адрес электронной почты. Если вы не получили письмо, проверьте папку «Спам» или запросите повторную отправку."
          }
        }
      }
    },
