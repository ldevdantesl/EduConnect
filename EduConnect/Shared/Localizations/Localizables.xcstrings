    "program_byCategoryFooterSubtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose a program that interests you and get a list of universities offering it. You’ll find out which universities have the program, what exams are required, the minimum and passing scores, and the tuition cost."
