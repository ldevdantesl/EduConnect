    "account_mainTabAdviceSection" : {
      "extractionState" : "manual",
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вот несколько советов, чтобы начать:"
          }
        }
      }
    },
    "account_mainTabAdviceSubtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "* Этот раздел — ваша личная панель. После того как вы добавите вуз в список, вы сможете отслеживать прогресс своей заявки.\\n* Все вузы потребуют от вас ответов на общие вопросы в анкете. Для подачи заявки в вуз перейдите в раздел Поиск вузов.\\n* Как только вы добавите вуз, сможете завершить и отправить вашу заявку в разделе Мои вузы.\\n\\nМы всегда готовы помочь вам на каждом шаге! Если у вас возникнут вопросы, вы можете обратиться в наш Центр поддержки абитуриентов или связаться с нами в любое время."
          }
        }
      }
    },
    "account_mainTabWelcomeMessage" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Congratulations on taking the first step toward admission to one of the best universities in Kazakhstan!\\nHere, you will be able to choose an educational institution, submit your application, and track the entire admission process."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Поздравляем вас с первым шагом на пути к поступлению в один из лучших вузов Казахстана!\\nЗдесь вы сможете выбрать учебное заведение,подать документы и отслеживать весь процесс поступления."
          }
        }
      }
    },
